# Variables de entorno del Frontend (Vite)
# ⚠️ IMPORTANTE: En Vite, las variables de entorno DEBEN empezar con VITE_
# para que sean accesibles en el código del navegador.
# Variables sin VITE_ solo existen en Node.js durante el build — no en el browser.

# URL base de nuestro backend Express
VITE_API_URL=http://localhost:3001


